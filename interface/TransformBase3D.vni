package pilot;

// See automy.basic.Transform3D

class TransformBase3D{
	long time;
	int time_offset = 0;
	string frame;
	string parent;

	rotation_type_e rotation_type;

	double offset[3];                                           // x, y, z [m, m, m]
	double rotation[3];                                         // roll, pitch, yaw [rad, rad, rad]
}
